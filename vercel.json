{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "ca-01.rrhosting.eu:7839/api/:path*"
    },
    {
      "source": "/transcripts/:path*",
      "destination": "ca-01.rrhosting.eu:7839/transcripts/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
